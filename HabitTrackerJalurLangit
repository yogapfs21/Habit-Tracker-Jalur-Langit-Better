    }



    



 function updateProgressMetrics() {

    const today = formatDateKey(new Date());

    const progress = calculateDailyProgress(today);

    const percentage = Math.round((progress.completed / progress.total) * 100) || 0;

    

    // 1. Update Persentase & Circle Progress

    const todayProgressEl = document.getElementById('todayProgress');

    if(todayProgressEl) todayProgressEl.textContent = percentage + '%';

    

    const evolutionEl = document.getElementById('todayEvolution');

    if(evolutionEl) evolutionEl.textContent = getEvolutionEmoji(percentage);

    

    const circle = document.getElementById('progressCircle');

    if(circle) {

        const circumference = 2 * Math.PI * 45;

        const strokeDashoffset = circumference - (percentage / 100) * circumference;

        circle.style.strokeDasharray = `${circumference - strokeDashoffset} ${circumference}`;

    }



    // 2. Update Period Bars (Pagi, Siang, dll)

    const periodProgress = calculateProgressByPeriod(today);

    for (const [periodKey, data] of Object.entries(periodProgress)) {

        const pText = document.getElementById(`periodProgress-${periodKey}`);

        const pBar = document.getElementById(`periodBar-${periodKey}`);

        if(pText) pText.textContent = data.percentage + '%';

        if(pBar) pBar.style.width = data.percentage + '%';

    }



    // 3. Update Total Padi

    let totalPadi = 0;

    getWeekDates(currentWeekStart).forEach(date => {

        const dp = calculateDailyProgress(formatDateKey(date));

        if (Math.round((dp.completed / dp.total) * 100) >= 81) totalPadi++;

    });

    const padiEl = document.getElementById('totalPadi');

    if(padiEl) padiEl.textContent = totalPadi;



    // 4. PANGGIL VISUALISASI (Grafik & Batang)

    // Gunakan setTimeout kecil agar elemen HTML sempat muncul dulu

    setTimeout(() => {

        updateWeeklyChart();

        renderVerticalProgress();

    }, 100);

}



function updateWeeklyChart() {

    const canvas = document.getElementById('weeklyChart');

    if (!canvas) return; // Jika elemen tidak ada, berhenti agar tidak error



    const ctx = canvas.getContext('2d');

    const weekDates = getWeekDates(currentWeekStart);

    const percentages = weekDates.map(date => {

        const p = calculateDailyProgress(formatDateKey(date));

        return Math.round((p.completed / p.total) * 100) || 0;

    });



    // Hancurkan chart lama jika ada agar tidak tumpang tindih

    if (window.weeklyChartInstance) {

        window.weeklyChartInstance.destroy();

    }



    // Buat Chart Baru

    window.weeklyChartInstance = new Chart(ctx, {

        type: 'line',

        data: {

            labels: weekDates.map(d => getDayName(d)),

            datasets: [{

                data: percentages,

                borderColor: '#FFD700',

                backgroundColor: 'rgba(255, 215, 0, 0.1)',

                borderWidth: 3,

                fill: true,

                tension: 0.4,

                pointRadius: 4,

                pointBackgroundColor: '#FFD700'

            }]

        },

        options: {

            responsive: true,

            maintainAspectRatio: false,

            scales: {

                y: { beginAtZero: true, max: 100, ticks: { color: '#9CA3AF', size: 10 } },

                x: { ticks: { color: '#9CA3AF', size: 10 } }

            },

            plugins: { legend: { display: false } }

        }

    });

}



function renderVerticalProgress() {

    const container = document.getElementById('verticalProgressBarContainer');

    if (!container) return;



    const weekDates = getWeekDates(currentWeekStart);

    const todayStr = formatDateKey(new Date());

    let html = '';



    weekDates.forEach(date => {

        const dateStr = formatDateKey(date);

        const progress = calculateDailyProgress(dateStr);

        const percentage = Math.round((progress.completed / progress.total) * 100) || 0;

        const isToday = dateStr === todayStr;



        let barColor = 'from-slate-600 to-slate-500'; 

        if (percentage > 0) barColor = 'from-orange-500 to-yellow-400';

        if (percentage >= 81) barColor = 'from-yellow-400 to-yellow-200';



        html += `

            <div class="flex flex-col items-center h-full w-full group">

                <div class="opacity-0 group-hover:opacity-100 transition-opacity bg-yellow-400 text-slate-900 text-[8px] font-bold px-1 rounded mb-1">

                    ${percentage}%

                </div>

                <div class="relative w-2.5 md:w-4 h-full bg-slate-700/50 rounded-full overflow-hidden flex flex-col justify-end border border-white/5">

                    <div class="bg-gradient-to-t ${barColor} w-full rounded-full transition-all duration-700" 

                         style="height: ${percentage}%">

                    </div>

                </div>

                <div class="mt-2 flex flex-col items-center">

                    <span class="text-[9px] ${isToday ? 'text-yellow-400 font-bold' : 'text-gray-500'}">${getDayName(date)}</span>

                    <span class="text-[9px] ${isToday ? 'bg-yellow-400 text-slate-900 rounded-full w-4 h-4 flex items-center justify-center font-bold' : 'text-gray-600'}">${date.getDate()}</span>

                </div>

            </div>`;

    });

    container.innerHTML = html;

}





