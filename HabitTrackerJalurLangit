function switchTab(tab) {
    currentTab = tab;

    // Mapping ID sesuai dengan yang ada di HTML kamu tadi
    const tabMap = {
        'habits': 'contentHabits',
        'sunnah': 'contentSunnah',
        'quran': 'contentQuran',
        'leaderboard': 'contentLeaderboard',
        'productive': 'contentproductive',
        'calendar': 'contentcalendar'
    };

    // 1. Sembunyikan semua konten & matikan semua ikon
    Object.keys(tabMap).forEach(key => {
        const contentEl = document.getElementById(tabMap[key]);
        // Cari ikon (id: tabHabitsIcon, tabSunnahIcon, dst)
        const iconId = 'tab' + key.charAt(0).toUpperCase() + key.slice(1) + 'Icon';
        const iconEl = document.getElementById(iconId);

        if (contentEl) contentEl.classList.add('hidden');
        if (iconEl) iconEl.classList.remove('active');
    });

    // 2. Tampilkan konten yang dipilih
    const activeId = tabMap[tab];
    const activeContent = document.getElementById(activeId);
    if (activeContent) {
        activeContent.classList.remove('hidden');
    }

    // 3. Aktifkan ikon yang dipilih
    const activeIconId = 'tab' + tab.charAt(0).toUpperCase() + tab.slice(1) + 'Icon';
    const activeIcon = document.getElementById(activeIconId);
    if (activeIcon) {
        activeIcon.classList.add('active');
    }

    // 4. Jalankan fungsi render spesifik
    if (tab === 'habits') { renderHabits(); updateProgressMetrics(); }
    else if (tab === 'sunnah') { renderSunnahTracker(); renderTasbihHistory(); }
    else if (tab === 'quran') { loadQuranData(); }
    else if (tab === 'leaderboard') { renderLeaderboard(); }
    else if (tab === 'productive') { renderProductiveTab(); updateClock(); }
    else if (tab === 'calendar') { renderCalendarTab(); }
    

    window.scrollTo(0, 0);
}




