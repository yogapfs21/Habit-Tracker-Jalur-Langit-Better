// 2. Fungsi untuk Menampilkan Modal Set Alarm



let currentAlarmHabitId = null; // Variabel pembantu global

let currentEditingAlarmId = null;

function openAlarmModal(habitId, habitName) {
currentEditingAlarmId = habitId;
document.getElementById('alarmHabitTitle').textContent = habitName;

// Ambil data alarm lama jika ada
const existing = allData.find(d => d.type === 'habit_alarm' && d.pin === currentUser?.pin && d.habit_id === habitId);

// Set nilai input (default 04:00 atau jam yang sudah ada)
// Input type="time" hanya menerima format HH:mm, jadi detik otomatis hilang
document.getElementById('habitAlarmInput').value = existing ? existing.alarm_time : "04:00";

document.getElementById('habitAlarmModal').classList.remove('hidden');
}

function closeHabitAlarmModal() {
document.getElementById('habitAlarmModal').classList.add('hidden');
currentEditingAlarmId = null;
}

function saveHabitAlarm() {
let alarmTime = document.getElementById('habitAlarmInput').value;
if (!alarmTime || !currentEditingAlarmId) return;

// PENGAMAN: Pastikan hanya mengambil 5 karakter pertama (HH:mm)
// Ini akan mengubah "20:57:00" menjadi "20:57"
if (alarmTime.length > 5) {
alarmTime = alarmTime.substring(0, 5);
}

const habitName = document.getElementById('alarmHabitTitle').textContent;
const alarmIdx = allData.findIndex(d => d.type === 'habit_alarm' && d.pin === currentUser?.pin && d.habit_id ===
currentEditingAlarmId);

if (alarmIdx !== -1) {
allData[alarmIdx].alarm_time = alarmTime;
allData[alarmIdx].last_fired = "";
} else {
allData.push({
type: 'habit_alarm',
pin: currentUser.pin,
habit_id: currentEditingAlarmId,
habit_name: habitName,
alarm_time: alarmTime,
last_fired: ""
});
}

saveToLocalStorage();
renderHabits();
closeHabitAlarmModal();
alert("Alarm diset untuk jam " + alarmTime);
}

function offHabitAlarm() {
if (!currentEditingAlarmId) return;
allData = allData.filter(d => !(d.type === 'habit_alarm' && d.pin === currentUser?.pin && d.habit_id ===
currentEditingAlarmId));
saveToLocalStorage();
renderHabits();
closeHabitAlarmModal();
alert("Alarm Dimatikan");
}

