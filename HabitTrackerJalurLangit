async function toggleHabit(habitId, dateStr) {



  if (!currentUser) return;





  // 1. Cari apakah data sudah ada di allData



  const index = allData.findIndex(d => 



    d.type === 'habit_completion' && 



    d.pin === currentUser.pin && 



    d.habit_id === habitId && 



    d.habit_date === dateStr



  );





  if (index !== -1) {



    // 2. Jika sudah ada, balikkan statusnya (toggle)



    allData[index].completed = !allData[index].completed;



  } else {



    // 3. Jika belum ada, buat data baru



    allData.push({



      type: 'habit_completion',



      pin: currentUser.pin,



      habit_id: habitId,



      habit_date: dateStr,



      completed: true



    });



  }





  // 4. SIMPAN KE DATABASE (LocalStorage)



  localStorage.setItem('jalurLangit_DB', JSON.stringify(allData));





  // 5. Update tampilan secara langsung



  renderHabits();



  updateProgressMetrics();



}



    



