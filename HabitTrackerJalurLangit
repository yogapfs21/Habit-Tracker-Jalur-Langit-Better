function generateCalendarGrid(month, year) {
    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const today = new Date();
    const isCurrentMonth = today.getMonth() === month && today.getFullYear() === year;

    // Ambil semua tanggal yang ada agendanya untuk user ini
    const taskDates = allData
        .filter(d => d.type === 'monthly_task' && d.pin === currentUser?.pin)
        .map(d => new Date(d.raw_date).getDate());

    let gridHtml = '';
    
    // Slot kosong untuk hari sebelum tanggal 1
    for (let i = 0; i < firstDay; i++) {
        gridHtml += `<div class="p-2 opacity-0"></div>`;
    }

    // Isi tanggal 1 sampai habis
    for (let day = 1; day <= daysInMonth; day++) {
        const isToday = isCurrentMonth && today.getDate() === day;
        const hasTask = taskDates.includes(day); // Cek apakah ada agenda di tanggal ini
        
        // Logika Warna: 
        // 1. Jika hari ini: Background Cyan Terang
        // 2. Jika ada agenda: Border Cyan & Teks Terang
        // 3. Biasa: Teks Abu-abu
        
        let classStyle = "p-2 rounded-lg text-sm transition-all relative ";
        
        if (isToday) {
            classStyle += "bg-cyan-500 text-white font-bold shadow-[0_0_15px_rgba(6,182,212,0.6)] z-10";
        } else if (hasTask) {
            classStyle += "text-cyan-300 font-bold border border-cyan-500/50 bg-cyan-500/10 shadow-[inset_0_0_8px_rgba(6,182,212,0.2)]";
        } else {
            classStyle += "text-gray-500 hover:bg-white/5";
        }

        gridHtml += `
            <div class="${classStyle}">
                ${day}
                ${hasTask && !isToday ? '<span class="absolute top-1 right-1 w-1 h-1 bg-yellow-400 rounded-full animate-pulse"></span>' : ''}
            </div>`;
    }
    
    return gridHtml;
}

