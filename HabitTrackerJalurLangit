// 1. FUNGSI MENAMPILKAN DAFTAR USER (KHUSUS ADMIN)
function loadUsersList() {
const container = document.getElementById('usersList');
if (!container) return;

// Ambil semua data tipe 'user' kecuali Admin (PIN 4799)
const users = allData.filter(d => d.type === 'user' && d.pin !== '4799');

if (users.length === 0) {
container.innerHTML = `
<div class="text-center py-8 border-2 border-dashed border-white/5 rounded-xl">
    <p class="text-gray-500 text-xs italic">Belum ada user yang terdaftar secara manual.</p>
</div>`;
return;
}

container.innerHTML = `
<div class="space-y-2">
    <div
        class="grid grid-cols-4 gap-2 p-2 bg-slate-900/50 rounded-lg text-[10px] font-bold text-yellow-400 uppercase tracking-widest sticky top-0">
        <div>PIN</div>
        <div>Nama</div>
        <div class="text-center">Status</div>
        <div class="text-right">Aksi</div>
    </div>
    ${users.map(user => {
    const isActive = user.status !== 'inactive';
    return `
    <div
        class="grid grid-cols-4 gap-2 p-3 bg-slate-800/40 rounded-xl border border-white/5 items-center hover:bg-slate-800/80 transition-all">
    <div class="font-mono text-yellow-400 font-bold">
        ${'*'.repeat(user.pin.length)}
    </div>
        <div class="truncate text-xs font-medium">${user.name}</div>
        <div class="flex justify-center">
            <button onclick="toggleUserStatus('${user.__backendId}')"
                            class="px-2 py-1 rounded text-[9px] font-bold uppercase transition-all ${isActive ? 'bg-green-500/20 text-green-400 border border-green-500/30' : 'bg-red-500/20 text-red-400 border border-red-500/30'}">
                            ${isActive ? 'Aktif' : 'Off'}
                        </button>
        </div>
        <div class="flex justify-end">
            <button onclick="deleteUser('${user.__backendId}')" class="p-2 bg-red-500/10 text-red-400 rounded-lg hover:bg-red-500/30 transition-colors">
                            🗑️
                        </button>
        </div>
    </div>`;
    }).join('')}
</div>
`;
}

// 2. FUNGSI UBAH STATUS USER (AKTIF/NONAKTIF)
function toggleUserStatus(userId) {
const userIdx = allData.findIndex(d => d.__backendId === userId);
if (userIdx === -1) return;

// Balikkan status
const currentStatus = allData[userIdx].status;
allData[userIdx].status = (currentStatus === 'inactive') ? 'active' : 'inactive';

saveToLocalStorage();
loadUsersList(); // Refresh list
}

// 3. FUNGSI HAPUS USER PERMANEN
function deleteUser(userId) {
const user = allData.find(d => d.__backendId === userId);
if (!user) return;

if (confirm(`Hapus user "${user.name}"? Semua data habitnya juga akan terhapus permanen.`)) {
// Hapus user-nya
allData = allData.filter(d => d.__backendId !== userId);
// Hapus semua data yang berkaitan dengan PIN user tersebut
allData = allData.filter(d => d.pin !== user.pin || d.type === 'user');

saveToLocalStorage();
loadUsersList(); // Refresh list
alert('User berhasil dihapus.');
}
}




