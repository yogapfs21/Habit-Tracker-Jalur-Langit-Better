    function calculateDailyProgress(dateStr) {



      const completions = allData.filter(d => 



        d.type === 'habit_completion' && 



        d.pin === currentUser?.pin && 



        d.habit_date === dateStr &&



        d.completed



      );



      



      let total = 0;



      for (const period of Object.values(defaultHabits)) {



        total += period.habits.length;



      }



      



      return {



        completed: completions.length,



        total: total



      };



    }



    



    function calculateProgressByPeriod(dateStr) {



      const results = {};



      



      for (const [periodKey, period] of Object.entries(defaultHabits)) {



        const completions = allData.filter(d => 



          d.type === 'habit_completion' && 



          d.pin === currentUser?.pin && 



          d.habit_date === dateStr &&



          d.completed &&



          period.habits.some(h => h.id === d.habit_id)



        );



        



        results[periodKey] = {



          completed: completions.length,



          total: period.habits.length,



          percentage: Math.round((completions.length / period.habits.length) * 100)



        };



      }



      



      return results;



    }



    



