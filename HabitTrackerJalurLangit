        function checkUpcomingDeadlines() {
        if (!currentUser) return;
        
        const today = new Date();
        today.setHours(0,0,0,0);
        
        const monthlyTasks = allData.filter(d =>
        d.type === 'monthly_task' &&
        d.pin === currentUser.pin &&
