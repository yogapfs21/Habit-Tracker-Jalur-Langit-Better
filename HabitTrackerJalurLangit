            }



            .chart-container {

                position: relative;

                height: 250px;

                width: 100%;

                margin-top: 10px;

            }



            /* Mode Card untuk Mobile */

            @media (max-width: 768px) {

                .habit-table-wrapper table {

                    display: block;

                }



                .habit-table-wrapper thead {

                    display: none;

                    /* Sembunyikan header tabel di mobile */

                }



                .habit-table-wrapper tr {

                    display: flex;

                    flex-direction: column;

                    border: 1px solid rgba(255, 215, 0, 0.2);

                    margin-bottom: 1rem;

                    border-radius: 12px;

                    padding: 10px;

                    background: rgba(255, 255, 255, 0.03);

                }



                .habit-table-wrapper td {

                    display: flex;

                    justify-content: space-between;

                    align-items: center;

                    padding: 8px 0;

                    border-bottom: 1px solid rgba(255, 255, 255, 0.05);

                }



                .habit-table-wrapper td:last-child {

                    border-bottom: none;

                }



                .habit-table-wrapper td::before {

                    content: attr(data-label);

                    /* Mengambil label hari (Sen, Sel, dst) */

                    font-size: 10px;

                    color: #9CA3AF;

                    text-transform: uppercase;

                }

            }



            /* Animasi Leaderboard */

            .leaderboard-item {

                transition: all 0.3s ease;

            }



            .leaderboard-item:hover {

                transform: translateX(10px);

                background: rgba(255, 215, 0, 0.1);

            }



            .star-btn {



                font-size: 2.5rem;

                /* Ukuran sedikit lebih besar agar ikon bintang terlihat jelas */



                line-height: 1;



                padding: 0.2rem;



                transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);

                /* Efek membal saat diklik */



                cursor: pointer;



                background: none;



                border: none;



                outline: none;



            }



            .star-btn:hover {



                transform: scale(1.2);



                color: rgba(255, 215, 0, 0.5);



            }







            .star-completed {



                color: #FFD700;



                /* Efek sinar (glow) keemasan */



                text-shadow: 0 0 12px rgba(255, 215, 0, 0.8), 0 0 20px rgba(255, 215, 0, 0.4);



                transform: scale(1.1);



            }







            .star-pending {



                color: rgba(156, 163, 175, 0.2);

                /* Warna abu-abu transparan saat belum diisi */



                text-shadow: none;



            }







            .golden-text {



                background: linear-gradient(135deg, #FFD700, #FFA500, #FFD700, #FFEC8B);



                background-size: 200% 200%;



                -webkit-background-clip: text;



                -webkit-text-fill-color: transparent;



                background-clip: text;



                animation: shimmer 3s ease-in-out infinite;



            }







            @keyframes shimmer {



                0%,

                100% {

                    background-position: 0% 50%;

                }



                50% {

                    background-position: 100% 50%;

                }



            }







            @keyframes glow {



                0%,

                100% {

                    box-shadow: 0 0 10px rgba(255, 215, 0, 0.3);

                }



                50% {

                    box-shadow: 0 0 20px rgba(255, 215, 0, 0.6);

                }



            }







            .glass-card {



                background: rgba(255, 255, 255, 0.1);



                backdrop-filter: blur(10px);



                border: 1px solid rgba(255, 255, 255, 0.2);



            }







            .tab-icon {



                transition: all 0.3s ease;



                color: rgba(255, 255, 255, 0.5);



            }







            .tab-icon.active {



                color: #FFD700;



                animation: glow 2s ease-in-out infinite;



            }







